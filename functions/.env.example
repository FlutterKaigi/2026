# Cloud Functions のデプロイ時パラメータ。
# このファイルを `.env` にコピーして値を設定する（`.env` は Git 管理外）。
#
#   cp functions/.env.example functions/.env
#
# 同期先（本番）の Firebase プロジェクト ID。
SYNC_TARGET_PROJECT_ID=

# 関数の実行サービスアカウント（最小権限の専用 SA を推奨。README 参照）。
# 未指定の場合は Compute デフォルト SA が使われる（compute API の有効化が必要）。
RUN_SERVICE_ACCOUNT=
