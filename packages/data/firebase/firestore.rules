rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasAdminAccess() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[^@]+@flutterkaigi[.]jp$')
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read, write: if false;
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /venues/{venueId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /speakers/{speakerId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /staffMembers/{staffMemberId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /timelineEvents/{timelineEventId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if hasAdminAccess();
    }

    match /quizEvents/{eventId} {
      allow read: if true;
      allow write: if hasAdminAccess();

      match /participants/{uid} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == uid
          && get(/databases/$(database)/documents/quizEvents/$(eventId)).data.status == 'registration'
          && request.resource.data.keys().hasOnly(['displayName', 'registeredAt'])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() >= 1
          && request.resource.data.displayName.size() <= 20
          && request.resource.data.registeredAt == request.time;
        allow update, delete: if hasAdminAccess();
      }

      match /teams/{teamId} {
        allow read: if true;
        allow write: if hasAdminAccess();
      }

      match /questions/{questionId} {
        // draft の問題（未出題の問題文・選択肢）は参加者から見えない。
        allow get: if hasAdminAccess() || resource.data.status != 'draft';
        allow list: if hasAdminAccess();
        allow write: if hasAdminAccess();

        match /secret/{secretId} {
          allow read, write: if hasAdminAccess();
        }
      }

      match /answers/{answerId} {
        // 自チームの回答のみ読める（他チームの回答の覗き見防止）。
        allow get: if hasAdminAccess()
          || (request.auth != null
              && request.auth.uid in get(/databases/$(database)/documents/quizEvents/$(eventId)/teams/$(resource.data.teamId)).data.memberUids);
        allow list: if hasAdminAccess();
        // 作成・削除は運営のみ（出題時に全チーム分を事前作成する）。
        allow create, delete: if hasAdminAccess();
        // 参加者は自チームの回答の選択のみ変更できる。isCorrect 等は書けない。
        allow update: if hasAdminAccess()
          || (request.auth != null
              && request.auth.uid in get(/databases/$(database)/documents/quizEvents/$(eventId)/teams/$(resource.data.teamId)).data.memberUids
              && get(/databases/$(database)/documents/quizEvents/$(eventId)/questions/$(resource.data.questionId)).data.status == 'open'
              && request.time < get(/databases/$(database)/documents/quizEvents/$(eventId)/questions/$(resource.data.questionId)).data.closesAt
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selectedOptionIndex', 'answeredBy', 'submittedAt'])
              && request.resource.data.selectedOptionIndex is int
              && request.resource.data.selectedOptionIndex >= 0
              && request.resource.data.selectedOptionIndex < get(/databases/$(database)/documents/quizEvents/$(eventId)/questions/$(resource.data.questionId)).data.options.size()
              && request.resource.data.answeredBy == request.auth.uid
              && request.resource.data.submittedAt == request.time);
      }
    }

    // 未定義のパスを明示的に拒否（多層防御）。
    // Firestore はデフォルトで拒否するが、コレクション追加時の取りこぼしを防ぐため明示する。
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
