{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlutterKaigi/2026/packages/data/firebase/schemas/firestore/quiz_question_secret.schema.json",
  "title": "QuizQuestionSecret",
  "description": "Firestore document schema for the `quizEvents/{eventId}/questions/{questionId}/secret/answer` document. Admin-only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correctOptionIndex",
    "explanation"
  ],
  "properties": {
    "correctOptionIndex": {
      "type": "integer",
      "minimum": 0
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ja",
        "en"
      ],
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      }
    }
  }
}
