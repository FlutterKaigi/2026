{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlutterKaigi/2026/packages/data/firebase/schemas/firestore/quiz_entry_secret.schema.json",
  "title": "QuizEntrySecret",
  "description": "Firestore document schema for `quizEvents/{eventId}/secret/entry` (venue entry code, admin-only).",
  "type": "object",
  "additionalProperties": false,
  "required": ["code"],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    }
  }
}
