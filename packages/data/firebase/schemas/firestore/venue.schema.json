{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlutterKaigi/2026/packages/data/firebase/schemas/firestore/venue.schema.json",
  "title": "Venue",
  "description": "Firestore document schema for the `venues` collection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "createdAt", "updatedAt"],
  "properties": {
    "name": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ja", "en"],
      "properties": {
        "ja": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      }
    },
    "order": {
      "type": ["integer", "null"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
