{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FlutterKaigi/2026/packages/data/firebase/schemas/firestore/quiz_question.schema.json",
  "title": "QuizQuestion",
  "description": "Firestore document schema for the `quizEvents/{eventId}/questions` subcollection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sponsorId", "order", "title", "options", "durationSeconds", "status"],
  "properties": {
    "sponsorId": {
      "type": "string",
      "minLength": 1
    },
    "order": {
      "type": "integer",
      "minimum": 0
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": { "type": "string" }
    },
    "durationSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "open", "closed", "revealed"]
    },
    "openedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "closesAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "correctOptionIndex": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "explanation": {
      "type": ["string", "null"]
    }
  }
}
